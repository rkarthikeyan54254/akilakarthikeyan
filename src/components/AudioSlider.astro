---
interface Props {
  stories: any[];
}

const { stories } = Astro.props;
---

<div class="relative group max-w-5xl mx-auto mb-16 px-4">
  <div class="overflow-hidden rounded-3xl bg-white shadow-2xl border border-gray-100">
    <div 
      id="audio-slider" 
      class="flex transition-transform duration-700 ease-out"
      style="transform: translateX(0%);"
    >
      {stories.map((story) => (
        <div class="w-full flex-shrink-0 relative h-[300px] md:h-[400px]">
          {/* Background Image with Blur */}
          <div 
            class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-110"
            style={`background-image: url('${story.image}');`}
          >
            <div class="absolute inset-0 bg-gradient-to-r from-gray-900 via-gray-900/80 to-transparent"></div>
          </div>

          {/* Content */}
          <div class="relative h-full flex flex-col justify-center px-8 md:px-16 max-w-2xl">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-blue-600 text-white text-[10px] font-bold uppercase tracking-[0.2em] px-3 py-1 rounded-full">
                Audio Now Available
              </span>
              <span class="text-blue-400">
                <i class="fa-solid fa-headphones text-lg animate-bounce"></i>
              </span>
            </div>
            
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight">
              {story.title}
            </h2>
            
            <p class="text-gray-300 text-sm md:text-lg mb-8 line-clamp-2 md:line-clamp-3 leading-relaxed">
              {story.description}
            </p>

            <div class="flex items-center gap-6">
              <a 
                href={story.url}
                class="bg-white text-gray-900 px-8 py-3 rounded-full font-bold hover:bg-blue-50 transition-all transform hover:scale-105 shadow-lg flex items-center gap-2"
              >
                <i class="fa-solid fa-play"></i>
                இப்போதே கேளுங்கள்
              </a>
              <div class="hidden md:flex items-center gap-2 text-gray-400 text-sm">
                <i class="fa-regular fa-clock"></i>
                {story.readingTime} நிமிடம்
              </div>
            </div>
          </div>

          {/* Decoration for UX */}
          <div class="absolute right-0 bottom-0 p-8 opacity-20 pointer-events-none">
            <i class="fa-solid fa-music text-9xl text-white"></i>
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* Navigation Dots */}
  <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 flex gap-2">
    {stories.map((_, i) => (
      <button 
        class="slider-dot w-2 h-2 rounded-full bg-gray-300 transition-all duration-300"
        data-index={i}
      ></button>
    ))}
  </div>

  {/* Navigation Arrows */}
  <button 
    id="prev-slide"
    class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/2 w-12 h-12 bg-white rounded-full shadow-xl border border-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:scale-110 transition-all z-10 opacity-0 group-hover:opacity-100"
  >
    <i class="fa-solid fa-chevron-left"></i>
  </button>
  <button 
    id="next-slide"
    class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 w-12 h-12 bg-white rounded-full shadow-xl border border-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-900 hover:scale-110 transition-all z-10 opacity-0 group-hover:opacity-100"
  >
    <i class="fa-solid fa-chevron-right"></i>
  </button>
</div>

<script>
  function initSlider() {
    const slider = document.getElementById('audio-slider');
    const dots = document.querySelectorAll('.slider-dot');
    const prevBtn = document.getElementById('prev-slide');
    const nextBtn = document.getElementById('next-slide');
    const slideCount = dots.length;
    
    if (!slider || slideCount === 0) return;

    let currentIndex = 0;
    let autoPlayInterval;

    function updateSlider() {
      slider.style.transform = `translateX(-${currentIndex * 100}%)`;
      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add('bg-blue-600', 'w-8');
          dot.classList.remove('bg-gray-300');
        } else {
          dot.classList.remove('bg-blue-600', 'w-8');
          dot.classList.add('bg-gray-300');
        }
      });
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % slideCount;
      updateSlider();
    }

    function prevSlide() {
      currentIndex = (currentIndex - 1 + slideCount) % slideCount;
      updateSlider();
    }

    nextBtn?.addEventListener('click', () => {
      nextSlide();
      resetAutoPlay();
    });

    prevBtn?.addEventListener('click', () => {
      prevSlide();
      resetAutoPlay();
    });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        currentIndex = parseInt(dot.getAttribute('data-index') || '0');
        updateSlider();
        resetAutoPlay();
      });
    });

    function resetAutoPlay() {
      clearInterval(autoPlayInterval);
      autoPlayInterval = setInterval(nextSlide, 5000);
    }

    updateSlider();
    resetAutoPlay();
  }

  // Handle Astro view transitions
  initSlider();
  document.addEventListener('astro:after-swap', initSlider);
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
