---
---

<div class="relative max-w-2xl mx-auto mb-12 px-4 sm:px-0">
  <div class="bg-white p-2 rounded-2xl shadow-xl border border-gray-100 flex items-center gap-2">
    <div class="pl-4 text-gray-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </div>
    <input 
      type="text" 
      id="unified-search"
      placeholder="கதைகள், புத்தகங்களைத் தேடுங்கள்..." 
      class="w-full py-3 px-2 focus:outline-none text-lg text-gray-700 rounded-lg"
      autocomplete="off"
    />
    <button 
      id="unified-search-btn"
      class="bg-gray-900 text-white px-6 py-3 rounded-xl font-medium hover:bg-gray-800 transition-colors whitespace-nowrap"
    >
      தேடு
    </button>
  </div>
  
  <div 
    id="unified-search-results" 
    class="absolute left-0 right-0 mx-4 sm:mx-0 mt-2 bg-white rounded-2xl shadow-2xl border border-gray-100 max-h-[70vh] overflow-y-auto hidden z-50 scrollbar-hide overflow-hidden"
  >
  </div>
</div>

<script>
  let searchData = [];
  let searchTimeout;

  async function fetchData() {
    try {
      const response = await fetch('/api/stories.json');
      searchData = await response.json();
    } catch (e) {
      console.error("Failed to fetch search data", e);
    }
  }

  async function initSearch() {
    await fetchData();
    
    const searchInput = document.getElementById('unified-search') as HTMLInputElement;
    const searchBtn = document.getElementById('unified-search-btn');
    const searchResults = document.getElementById('unified-search-results');

    const handleSearchClick = () => {
      const query = searchInput.value.trim();
      if (query) {
        // If it's a general search, go to stories page with search param
        window.location.href = `/stories?search=${encodeURIComponent(query)}`;
      }
    };

    searchBtn?.addEventListener('click', handleSearchClick);
    
    searchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        handleSearchClick();
      }
    });

    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.normalize('NFC').toLowerCase();
      
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      searchTimeout = setTimeout(() => {
        if (query.length < 2) {
          searchResults?.classList.add('hidden');
          return;
        }

        const filtered = searchData.filter(item => {
          const title = item.title.normalize('NFC').toLowerCase();
          const description = (item.description || '').normalize('NFC').toLowerCase();
          return title.includes(query) || description.includes(query);
        });

        if (searchResults) {
          if (filtered.length > 0) {
            searchResults.innerHTML = filtered.map(item => `
              <a 
                href="${item.url}" 
                class="block p-4 hover:bg-gray-50 border-b border-gray-50 last:border-b-0 group transition-colors"
              >
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="font-bold text-gray-900 group-hover:text-gray-700 transition-colors">${item.title}</h3>
                    <p class="text-sm text-gray-500 line-clamp-2 mt-1">${item.description}</p>
                  </div>
                  <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider ${
                    item.type === 'book' ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700'
                  }">
                    ${item.type === 'book' ? 'புத்தகம்' : 'கதை'}
                  </span>
                </div>
              </a>
            `).join('');
          } else {
            searchResults.innerHTML = '<div class="p-6 text-center text-gray-500">முடிவுகள் எதுவும் கிடைக்கவில்லை</div>';
          }
          
          searchResults.classList.remove('hidden');
        }
      }, 200);
    });

    // Close results when clicking outside
    document.addEventListener('click', (e) => {
      if (!searchInput?.contains(e.target as Node) && !searchResults?.contains(e.target as Node)) {
        searchResults?.classList.add('hidden');
      }
    });
  }

  initSearch();
</script>
