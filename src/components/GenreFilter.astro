---
interface Props {
  currentGenre?: string;
  genres: string[];
  type?: 'stories' | 'books';
}

const { currentGenre, genres, type = 'stories' } = Astro.props;
---

<div class="mb-8 overflow-x-auto scrollbar-hide">
  <div class="flex flex-nowrap sm:flex-wrap gap-2 sm:gap-3 py-2">
    <a
      href={`/${type}`}
      class={`px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors shadow-sm ${
        !currentGenre 
          ? 'bg-gray-900 text-white' 
          : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'
      }`}
    >
      அனைத்தும்
    </a>
    {genres.map(genre => (
      <a
        href={`/${type}/genre/${genre}`}
        class={`px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors shadow-sm ${
          currentGenre === genre
            ? 'bg-gray-900 text-white'
            : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50'
        }`}
      >
        {genre}
      </a>
    ))}
  </div>
</div>