---
import Layout from '../../layouts/Layout.astro';
import CommentSection from '../../components/CommentSection.astro';
import ShareButton from '../../components/ShareButton.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const currentUrl = Astro.url.href;

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map(story => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await story.render();

// Check if content already contains the featured image to avoid duplication
const hasFeaturedImageInContent = story.body.includes(story.data.image || '');

const formattedDate = new Date(story.data.publishDate).toLocaleDateString('ta-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${story.data.title} - அகிலா கார்த்திகேயன்`}
  description={story.data.description}
  image={story.data.image}
  currentUrl={currentUrl}>

  <article class="prose prose-lg mx-auto px-4">
    {story.data.image && !hasFeaturedImageInContent && (
      <img 
        src={story.data.image} 
        alt={story.data.title} 
        class="w-full rounded-xl shadow-lg mb-8"
      />
    )}
    <h1 class="text-4xl font-bold text-gray-900 mb-4">{story.data.title}</h1>
    
    <div class="flex items-center gap-4 text-gray-600 mb-8">
      <time datetime={story.data.publishDate.toISOString()}>{formattedDate}</time>
      <span>எழுதியவர்: {story.data.author}</span>
      <span class="px-3 py-1 bg-gray-100 rounded-full text-sm">
        {story.data.genre}
      </span>
    </div>

    <div class="story-content mt-8">
      <Content currentUrl={currentUrl} />
    </div>

    <ShareButton title={story.data.title} url={currentUrl} />

    <CommentSection storySlug={story.slug} />
  </article>
</Layout>

<style>
  .prose {
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }
  
  .story-content {
    font-size: 1.2rem;
    line-height: 1.8;
  }
</style>