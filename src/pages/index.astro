---
import Layout from '../layouts/Layout.astro';
import StoryCard from '../components/StoryCard.astro';
import SearchBar from '../components/SearchBar.astro';
import AudioSlider from '../components/AudioSlider.astro';
import { getCollection } from 'astro:content';
import { supabase } from '../lib/supabase';

// 1. Fetch Static Stories
const staticStories = await getCollection('stories');
const formattedStaticStories = staticStories.map(s => {
  const words = s.body.split(/\s+/).length || 0;
  return {
    title: s.data.title,
    description: s.data.description,
    slug: s.slug,
    publishDate: s.data.publishDate,
    genre: s.data.genre,
    image: s.data.image,
    isDynamic: false,
    readingTime: Math.max(1, Math.ceil(words / 200)),
    hasAudio: !!(s.data as any).audio_url
  };
});

// 2. Fetch Dynamic Stories from Supabase
let dynamicStories = [];
try {
  const { data, error } = await supabase
    .from('stories')
    .select('*')
    .order('published_at', { ascending: false });
  
  if (!error && data) {
    dynamicStories = data.map(s => {
      const words = s.content.split(/\s+/).length || 0;
      return {
        title: s.title,
        description: s.excerpt || '',
        slug: s.slug,
        publishDate: new Date(s.published_at),
        genre: s.genre,
        image: s.image_url,
        isDynamic: true,
        readingTime: Math.max(1, Math.ceil(words / 200)),
        hasAudio: !!s.audio_url
      };
    });
  }
} catch (e) {}

// 3. Combine and filter
const allStories = [...formattedStaticStories, ...dynamicStories];

// Filter Featured for list
const featuredStories = allStories
  .filter(story => {
    // If dynamic, assume it's valid to show (or add a featured flag to DB later)
    // If static, check the featured flag
    if (!story.isDynamic) {
      const original = staticStories.find(s => s.slug === story.slug);
      return original?.data.featured;
    }
    return true; // Show dynamic stories in list if needed, or filter by logic
  })
  .sort((a, b) => b.publishDate.valueOf() - a.publishDate.valueOf())
  .slice(0, 6); // Limit to 6

// Filter Audio Stories for Slider
const audioStories = allStories
  .filter(story => story.hasAudio)
  .map(story => ({
    ...story,
    url: `/stories/${story.slug}`
  }));
---

<Layout 
  title="அகிலா கார்த்திகேயன் - எழுத்தாளர்"
  description="அரசுப்பணி தந்த அனுபவத்தையும், கல்கி முதல் மங்கையர் மலர் வரையிலான எழுத்துப் பயணத்தையும் இணைத்து, வாழ்வின் எதார்த்தங்களை நகைச்சுவையோடும் ஆன்மீகத்தோடும் ஆவணப்படுத்தும் அகிலா கார்த்திகேயனின் அதிகாரப்பூர்வத் தளம்."
  image="/images/ak_story.jpg"
>

  <section class="py-12 md:py-20">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
      <div class="relative w-48 h-48 md:w-64 md:h-64 flex-shrink-0">
        <div class="absolute inset-0 bg-gray-200 rounded-full animate-pulse -z-10"></div>
        <img
          src="/images/akilakarthikeyan_profile.jpg"
          alt="அகிலா கார்த்திகேயன்"
          class="w-full h-full object-cover rounded-full shadow-2xl border-8 border-white" 
        />
      </div>
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          அகிலா கார்த்திகேயன்
        </h1>
        <div class="space-y-4 text-lg md:text-xl text-gray-700 leading-relaxed">
          <p class="font-semibold text-gray-900">
            நகைச்சுவை தெறிக்கும் நையாண்டி; பக்தி மணம் கமழும் ஆன்மீகம்!
          </p>
          <p>
            அரசுப்பணி தந்த அனுபவத்தையும், கல்கி முதல் மங்கையர் மலர் வரையிலான எழுத்துப் பயணத்தையும் இணைத்து, வாழ்வின் எதார்த்தங்களை நகைச்சுவையோடும் ஆன்மீகத்தோடும் ஆவணப்படுத்தும் அகிலா கார்த்திகேயனின் அதிகாரப்பூர்வத் தளம்.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap justify-center md:justify-start gap-4">
          <a
            href="/stories"
            class="bg-gray-900 text-white px-8 py-3 rounded-full font-semibold hover:bg-gray-800 transition-all transform hover:scale-105 shadow-lg"
          >
            கதைகளை வாசிக்க
          </a>
          <a
            href="/about"
            class="bg-white text-gray-900 border-2 border-gray-200 px-8 py-3 rounded-full font-semibold hover:bg-gray-50 transition-all transform hover:scale-105 shadow-sm"
          >
            பற்றி அறிய
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16 -mt-8 relative z-10">
    <SearchBar />
  </section>

  {audioStories.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 px-4 max-w-7xl mx-auto flex items-center gap-3">
        <span class="w-1 h-8 bg-blue-600 rounded-full"></span>
        கேட்கக்கூடிய கதைகள்
      </h2>
      <AudioSlider stories={audioStories} />
    </section>
  )}

  <section class="mb-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">சிறப்பு கதைகள்</h2>
      <a href="/stories" class="text-gray-600 hover:text-gray-900 font-medium">அனைத்தும் காண்க &rarr;</a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredStories.map(story => (
        <StoryCard
          title={story.title}
          description={story.description}
          url={`/stories/${story.slug}`}
          publishDate={story.publishDate}
          genre={story.genre}
          image={story.image}
          readingTime={story.readingTime}
          hasAudio={story.hasAudio}
        />
      ))}
    </div>
  </section>

  <div class="text-center mt-12">
    <a
      href="/stories"
      class="inline-block bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-800 transition-colors"
    >
      அனைத்து கதைகளையும் காண்க
    </a>
  </div>
</Layout>
