---
import Layout from '../../layouts/Layout.astro';
import BookCard from '../../components/BookCard.astro';
import GenreFilter from '../../components/GenreFilter.astro';
import SearchBar from '../../components/SearchBar.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const sortedBooks = books.sort((a, b) => 
  b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// Get unique genres
const genres = [...new Set(books.map(book => book.data.genre))];
---

<Layout title="புத்தகங்கள் - அகிலா கார்த்திகேயன்">
  <div class="mb-12">
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">புத்தகங்கள்</h1>
    <div class="h-1 w-20 bg-gray-900 rounded-full"></div>
  </div>
  
  <SearchBar />
  <GenreFilter type="books" genres={genres} />
  
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {sortedBooks.map(book => (
      <BookCard book={book} />
    ))}
  </div>
</Layout>